# ── Lexora — Variables d'environnement ────────────────────────
# Copiez ce fichier vers lexora/.env et renseignez vos valeurs.
# Ne commitez JAMAIS le fichier .env réel.

# ── Serveur ────────────────────────────────────────────────────
# Port du serveur Express backend
PORT=3000

# ── Base de données ────────────────────────────────────────────
# Chemin vers le fichier SQLite (relatif au répertoire du backend)
# En Docker : /app/data/lexora.db (monté dans le volume sqlite-data)
DB_PATH=./lexora.db

# ── Sécurité ───────────────────────────────────────────────────
# Identifiants de l'administrateur (utilisés pour obtenir un JWT via POST /api/auth/login)
ADMIN_EMAIL=admin@lexora.fr
ADMIN_PASSWORD=changez-moi-avant-la-mise-en-production

# Clé secrète pour signer les JWT (chaîne longue et aléatoire)
# Exemple : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=changez-moi-avant-la-mise-en-production

# ── Assistant IA (Ollama) ──────────────────────────────────────
# URL du serveur Ollama
# En développement local : http://localhost:11434
# En Docker : http://host.docker.internal:11434 (accède au host depuis le conteneur)
OLLAMA_URL=http://localhost:11434

# Modèle Ollama à utiliser (doit être installé sur le serveur Ollama)
# Pour l'installer : ollama pull llama3.2
OLLAMA_MODEL=llama3.2
