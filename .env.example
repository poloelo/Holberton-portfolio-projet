# ── Lexora — Variables d'environnement ────────────────────────
# Copiez ce fichier vers .env et renseignez vos valeurs.
# Ne commitez JAMAIS le fichier .env réel.

# ── Serveur ────────────────────────────────────────────────────
PORT=3000

# ── Base de données ────────────────────────────────────────────
# En Docker : /app/data/lexora.db (monté dans le volume sqlite-data)
DB_PATH=./lexora.db

# ── Auth JWT ───────────────────────────────────────────────────
# Clé secrète pour signer les tokens JWT
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=changez-moi-avant-la-mise-en-production

# ── Sécurité ───────────────────────────────────────────────────
# Clé secrète pour protéger les routes d'administration
ADMIN_KEY=changez-moi-avant-la-mise-en-production

# ── CORS ───────────────────────────────────────────────────────
# Origines autorisées à appeler l'API (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost,http://localhost:80

# ── Assistant IA (Ollama) ──────────────────────────────────────
# En développement local : http://localhost:11434
# En Docker : http://host.docker.internal:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
